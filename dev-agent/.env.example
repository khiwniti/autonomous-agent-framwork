# =============================================================================
# Autonomous Development Agent Configuration
# =============================================================================

# Application Settings
AGENT_APP_NAME="Autonomous Dev Agent"
AGENT_ENVIRONMENT="development"  # development | staging | production
AGENT_DEBUG=true

# =============================================================================
# LLM Configuration
# =============================================================================

# Provider: openai | ollama | vllm
AGENT_LLM_PROVIDER="openai"

# OpenAI-Compatible API
AGENT_LLM_API_BASE_URL="https://api.openai.com/v1"
AGENT_LLM_API_KEY="your-api-key-here"

# For Ollama (local models)
# AGENT_LLM_API_BASE_URL="http://localhost:11434/v1"
# AGENT_LLM_API_KEY="ollama"

# For vLLM
# AGENT_LLM_API_BASE_URL="http://localhost:8000/v1"
# AGENT_LLM_API_KEY="vllm"

# Model Configuration
AGENT_LLM_MODEL="gpt-4-turbo-preview"
AGENT_LLM_TEMPERATURE=0.7
AGENT_LLM_MAX_TOKENS=4096
AGENT_LLM_TIMEOUT=60

# Token Budget
AGENT_TOKEN_MAX_CONTEXT=128000
AGENT_TOKEN_MAX_MESSAGES=20
AGENT_TOKEN_SUMMARIZATION_THRESHOLD=0.8

# =============================================================================
# Memory Configuration
# =============================================================================

# Backend: redis | in-memory
AGENT_MEMORY_BACKEND="in-memory"
AGENT_MEMORY_TTL=3600

# Redis (if using redis backend)
# AGENT_REDIS_URL="redis://localhost:6379/0"

# =============================================================================
# Agent Configuration
# =============================================================================

AGENT_AGENT_MAX_ITERATIONS=25
AGENT_AGENT_REFLECTION_INTERVAL=5
AGENT_AGENT_ENABLE_CHECKPOINTS=true

# =============================================================================
# Tool Configuration
# =============================================================================

AGENT_TOOL_EXECUTION_TIMEOUT=300
AGENT_TOOL_MAX_RETRIES=3

# =============================================================================
# Sandbox Configuration
# =============================================================================

AGENT_SANDBOX_ENABLED=true
AGENT_SANDBOX_NETWORK_MODE="none"  # none | bridge | host
AGENT_SANDBOX_CPU_QUOTA=200000  # 2 cores
AGENT_SANDBOX_MEMORY_LIMIT="4g"
AGENT_SANDBOX_PIDS_LIMIT=100
AGENT_SANDBOX_AUTO_REMOVE=true

# =============================================================================
# API Configuration
# =============================================================================

AGENT_API_HOST="0.0.0.0"
AGENT_API_PORT=8000
AGENT_API_WORKERS=4

# =============================================================================
# Logging & Observability
# =============================================================================

AGENT_LOG_LEVEL="INFO"  # DEBUG | INFO | WARNING | ERROR | CRITICAL
AGENT_LOG_FORMAT="console"  # console | json

AGENT_METRICS_ENABLED=false
AGENT_TRACING_ENABLED=false
# AGENT_JAEGER_ENDPOINT="http://localhost:14268/api/traces"

# =============================================================================
# Security
# =============================================================================

AGENT_SECURITY_ENABLE_AUTH=false
# AGENT_SECURITY_SECRET_KEY="your-secret-key-here"
AGENT_SECURITY_TOKEN_EXPIRY=86400
